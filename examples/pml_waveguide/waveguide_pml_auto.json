{
  // Same as waveguide_pml.json but with auto-detected PML geometry: no "Direction",
  // no "Thickness" — MaterialOperator computes them from the per-attribute and global
  // mesh bounding boxes.
  "Problem":
  {
    "Type": "Driven",
    "Verbose": 2,
    "Output": "postpro/waveguide_pml_auto"
  },
  "Model": { "Mesh": "mesh/waveguide.msh", "L0": 1.0 },
  "Domains":
  {
    "Materials":
    [
      { "Attributes": [1], "Permeability": 1.0, "Permittivity": 1.0 },
      { "Attributes": [2], "Permeability": 1.0, "Permittivity": 1.0,
        "PML":
        {
          "StretchFormulation": "Fixed",
          "ReferenceFrequency": 3.0
        }
      }
    ]
  },
  "Boundaries":
  {
    "WavePort":
    [
      { "Index": 1, "Attributes": [3], "Mode": 1, "Excitation": true }
    ],
    "PEC": { "Attributes": [4, 5] }
  },
  "Solver":
  {
    "Order": 2, "Device": "CPU",
    "Driven": { "MinFreq": 3.0, "MaxFreq": 3.0, "FreqStep": 0.5, "SaveStep": 1 },
    "Linear":
    {
      "Type": "STRUMPACK", "KSPType": "GMRES", "Tol": 1.0e-8, "MaxIts": 100,
      "MGMaxLevels": 1, "ComplexCoarseSolve": true
    }
  }
}

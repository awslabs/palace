{
  // Test: PML on the guide's +z end (attribute 2), terminated with PEC on the
  // outer face (attribute 5). The PML absorbs the TE10 mode; |S11| should be
  // orders of magnitude smaller than the 2nd-order ABC baseline.
  //
  // Reference frequency = 3 GHz (matches MinFreq/MaxFreq).
  "Problem":
  {
    "Type": "Driven",
    "Verbose": 2,
    "Output": "postpro/waveguide_pml_cfs"
  },
  "Model": { "Mesh": "mesh/waveguide.msh", "L0": 1.0 },
  "Domains":
  {
    "Materials":
    [
      { "Attributes": [1], "Permeability": 1.0, "Permittivity": 1.0 },
      { "Attributes": [2], "Permeability": 1.0, "Permittivity": 1.0,
        "PML":
        {
          "Direction": ["+z"],
          "Thickness": 0.1,
          "Order": 3,
          "KappaMax": 2.0, "AlphaMax": 0.1, "StretchFormulation": "CFS",
          "ReferenceFrequency": 3.0
        }
      }
    ]
  },
  "Boundaries":
  {
    "WavePort":
    [
      { "Index": 1, "Attributes": [3], "Mode": 1, "Excitation": true }
    ],
    "PEC": { "Attributes": [4, 5] }
  },
  "Solver":
  {
    "Order": 2, "Device": "CPU",
    "Driven": { "MinFreq": 3.0, "MaxFreq": 3.0, "FreqStep": 0.5, "SaveStep": 1 },
    "Linear":
    {
      "Type": "STRUMPACK", "KSPType": "GMRES", "Tol": 1.0e-8, "MaxIts": 100,
      "MGMaxLevels": 1, "ComplexCoarseSolve": true
    }
  }
}

+   Vector shape(fe.GetDof());
+   fe.CalcShape(ip, shape);
+   active.SetSize(0);
+   for (int i = 0; i < shape.Size(); i++)
+   {
+      if (shape(i) > kEntityTol) { active.Append(i); }
+   }
+}

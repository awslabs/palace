{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Configuration File Schema -- \"Domains\"",
  "type": "object",
  "additionalProperties": false,
  "required": ["Materials"],
  "properties":
  {
    "Materials":
    {
      "type": "array",
      "additionalItems": false,
      "items": { "$ref": "#/$defs/Material" }
    },
    "CurrentDipole":
    {
      "type": "array",
      "additionalItems": false,
      "items": { "$ref": "#/$defs/CurrentDipole" }
    },
    "Postprocessing": { "$ref": "#/$defs/DomainPostprocessing" }
  },
  "$defs":
  {
    "Material":
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["Attributes"],
      "properties":
      {
        "Attributes": { "$ref": "#/$defs/Attributes" },
        "Permeability": { "$ref": "#/$defs/ScalarOrVector3" },
        "Permittivity": { "$ref": "#/$defs/ScalarOrVector3" },
        "LossTan": { "$ref": "#/$defs/ScalarOrVector3" },
        "Conductivity": { "$ref": "#/$defs/ScalarOrVector3" },
        "LondonDepth": { "type": "number" },
        "MaterialAxes":
        {
          "type": "array",
          "items": { "$ref": "#/$defs/Vector3" },
          "minItems": 3,
          "maxItems": 3
        }
      }
    },
    "CurrentDipole":
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["Index", "Moment", "Center", "Direction"],
      "properties":
      {
        "Index": { "type": "integer", "exclusiveMinimum": 0 },
        "Moment": { "type": "number" },
        "Center": { "$ref": "#/$defs/Vector3" },
        "Direction":
        {
          "anyOf":
          [
            { "$ref": "#/$defs/DipoleDirection" },
            { "$ref": "#/$defs/Vector3" }
          ]
        }
      }
    },
    "DomainPostprocessing":
    {
      "type": "object",
      "additionalProperties": false,
      "required": [],
      "properties":
      {
        "Energy":
        {
          "type": "array",
          "additionalItems": false,
          "items": { "$ref": "#/$defs/Energy" }
        },
        "Probe":
        {
          "type": "array",
          "additionalItems": false,
          "items": { "$ref": "#/$defs/Probe" }
        }
      }
    },
    "Energy":
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["Index", "Attributes"],
      "properties":
      {
        "Index": { "type": "integer", "exclusiveMinimum": 0 },
        "Attributes": { "$ref": "#/$defs/Attributes" }
      }
    },
    "Probe":
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["Index", "Center"],
      "properties":
      {
        "Index": { "type": "integer", "exclusiveMinimum": 0 },
        "Center": { "$ref": "#/$defs/Vector3" }
      }
    },
    "Attributes":
    {
      "type": "array",
      "additionalItems": false,
      "items": { "type": "integer" },
      "minItems": 1
    },
    "Vector3":
    {
      "type": "array",
      "additionalItems": false,
      "items": { "type": "number" },
      "minItems": 3,
      "maxItems": 3
    },
    "ScalarOrVector3":
    {
      "oneOf":
      [
        { "type": "number" },
        { "$ref": "#/$defs/Vector3" }
      ]
    },
    "DipoleDirection":
    {
      "type": "string",
      "enum": ["X", "Y", "Z", "+X", "+Y", "+Z", "-X", "-Y", "-Z",
               "x", "y", "z", "+x", "+y", "+z", "-x", "-y", "-z"]
    }
  }
}

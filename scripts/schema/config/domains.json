{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Configuration File Schema -- \"Domains\"",
  "type": "object",
  "additionalProperties": false,
  "required": ["Materials"],
  "properties":
  {
    "Materials":
    {
      "type": "array",
      "additionalItems": false,
      "items":
      {
        "type": "object",
        "additionalProperties": false,
        "required": ["Attributes"],
        "properties":
        {
          "Attributes": { "$ref": "#/$defs/Attributes" },
          "Permeability":
          {
            "oneOf" :
            [
              {"type": "number" },
              {
                "type": "array",
                "items" : { "type" :"number" },
                "minItems" : 3,
                "maxItems" : 3
              }
            ]
          },
          "Permittivity":
          {
            "oneOf" :
            [
              {"type": "number" },
              {
                "type": "array",
                "items" : { "type" :"number" },
                "minItems" : 3,
                "maxItems" : 3
              }
            ]
          },
          "LossTan":
          {
            "oneOf" :
            [
              {"type": "number" },
              {
                "type": "array",
                "items" : { "type" :"number" },
                "minItems" : 3,
                "maxItems" : 3
              }
            ]
          },
          "Conductivity":
          {
            "oneOf" :
            [
              {"type": "number" },
              {
                "type": "array",
                "items" : { "type" :"number" },
                "minItems" : 3,
                "maxItems" : 3
              }
            ]
          },
          "LondonDepth": { "type": "number" },
          "MaterialAxes":
          {
            "type" : "array",
            "items" :
            {
              "type" : "array",
              "items" : { "type": "number" },
              "minItems" : 3,
              "maxItems" : 3
            },
            "minItems" : 3,
            "maxItems" : 3
          },
          "PML":
          {
            "type": "object",
            "additionalProperties": false,
            "properties":
            {
              "CoordinateType": { "type": "string", "enum": ["Cartesian"] },
              "Direction":
              {
                "type": "array",
                "items": { "type": "string" },
                "maxItems": 6
              },
              "Thickness":
              {
                "oneOf":
                [
                  { "type": "number" },
                  {
                    "type": "array",
                    "items": { "type": "number" },
                    "minItems": 6,
                    "maxItems": 6
                  }
                ]
              },
              "Order": { "type": "integer", "minimum": 2 },
              "SigmaMax":
              {
                "oneOf":
                [
                  { "type": "null" },
                  { "type": "number" },
                  {
                    "type": "array",
                    "items": { "type": "number" },
                    "minItems": 3,
                    "maxItems": 3
                  }
                ]
              },
              "KappaMax":
              {
                "oneOf":
                [
                  { "type": "number" },
                  {
                    "type": "array",
                    "items": { "type": "number" },
                    "minItems": 3,
                    "maxItems": 3
                  }
                ]
              },
              "AlphaMax":
              {
                "oneOf":
                [
                  { "type": "number" },
                  {
                    "type": "array",
                    "items": { "type": "number" },
                    "minItems": 3,
                    "maxItems": 3
                  }
                ]
              },
              "ReflectionTarget": { "type": "number", "exclusiveMinimum": 0 },
              "StretchFormulation":
              {
                "type": "string",
                "enum": ["Fixed", "CFS", "FrequencyDependent"]
              },
              "ReferenceFrequency": { "type": "number" },
              "AllowRefinement": { "type": "boolean" }
            }
          }
        }
      }
    },
    "CurrentDipole":
    {
      "type": "array",
      "additionalItems": false,
      "items":
      {
        "type": "object",
        "additionalProperties": false,
        "required": ["Index", "Moment", "Center", "Direction"],
        "properties":
        {
          "Index": { "type": "integer", "exclusiveMinimum": 0 },
          "Moment": { "type": "number" },
          "Center":
          {
            "type": "array",
            "additionalItems": false,
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          },
          "Direction":
          {
            "anyOf":
            [
              {
                "type": "string",
                "enum": ["X", "Y", "Z", "+X", "+Y", "+Z", "-X", "-Y", "-Z",
                         "x", "y", "z", "+x", "+y", "+z", "-x", "-y", "-z"]
              },
              {
                "type": "array",
                "additionalItems": false,
                "items": { "type": "number" },
                "minItems": 3,
                "maxItems": 3
              }
            ]
          }
        }
      }
    },
    "Postprocessing":
    {
      "type": "object",
      "additionalProperties": false,
      "required": [],
      "properties":
      {
        "Energy":
        {
          "type": "array",
          "additionalItems": false,
          "items":
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["Index", "Attributes"],
            "properties":
            {
              "Index": { "type": "integer", "exclusiveMinimum": 0 },
              "Attributes": { "$ref": "#/$defs/Attributes" }
            }
          }
        },
        "Probe":
        {
          "type": "array",
          "additionalItems": false,
          "items":
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["Index", "Center"],
            "properties":
            {
              "Index": { "type": "integer", "exclusiveMinimum": 0 },
              "Center":
              {
                "type": "array",
                "additionalItems": false,
                "items": { "type": "number" },
                "minItems": 3,
                "maxItems": 3
              }
            }
          }
        }
      }
    }
  },
  "$defs":
  {
    "Attributes":
    {
      "type": "array",
      "additionalItems": false,
      "items": { "type": "integer"},
      "minItems": 1
    }
  }
}

# Relocatable CTest entry point for an *installed* palace-unit-tests (no build
# tree). `catch_discover_tests` only writes build-tree CTestTestfiles, so the
# install-only Spack test jobs have nothing for `ctest` to run. This preamble
# plus the add_test() lines appended by CMake are installed next to the test
# data, so those jobs can:
#
#   ctest --test-dir <prefix>/share/palace/test -L "^regression$"
#
# palace-unit-tests must be on PATH (e.g. via `spack load palace`). Ranks,
# OpenMP threads, and PROCESSORS follow the build-time PALACE_TESTS_* contract.
# The linear solver and device are read from the environment so one installed
# build can be exercised against every solver in the CI matrix without a
# rebuild. The case list is fixed at configure time (no discovery at ctest
# time, whose script interpreter truncates large execute_process output).

find_program(_palace_bin NAMES palace-unit-tests)
if(NOT _palace_bin)
  set(_palace_bin palace-unit-tests)
endif()

set(_palace_args "")
if(NOT "$ENV{PALACE_TEST_LINEAR_SOLVER}" STREQUAL "")
  list(APPEND _palace_args "--palace-linear-solver" "$ENV{PALACE_TEST_LINEAR_SOLVER}")
endif()
if(NOT "$ENV{PALACE_TEST_DEVICE}" STREQUAL "")
  list(APPEND _palace_args "--device" "$ENV{PALACE_TEST_DEVICE}")
endif()

++      return;
++  }
++
++  gkMPI_Comm_size(nonzeroComm, &npesNonzero);
++  gkMPI_Comm_rank(nonzeroComm, &mypeNonzero);
++
++  /* Compress the vtxdist data to make it match the new communicator */
++  j=0;
++  for( i=1; i<npes+1; ++i )

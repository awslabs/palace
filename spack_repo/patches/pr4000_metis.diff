++  MPI_Comm *comm )
++{
++  idx_t i, j, npes, npesNonzero, mype, mypeNonzero, dbglvl, status, haveData;
++  ctrl_t *ctrl;
++  graph_t *graph;
++  MPI_Comm nonzeroComm, nullComm;
++  size_t curmem;
++
++  gkMPI_Comm_size(*comm, &npes);
++  gkMPI_Comm_rank(*comm, &mype);
++
++  if( vtxdist[npes] == 0 )
++  {
++      sizes[0] = 0;
++      sizes[1] = 0;
++      sizes[2] = 0;
++      return;
++  }
++
++  haveData = ( vtxdist[mype+1]-vtxdist[mype] != 0 );
++  if( haveData )
